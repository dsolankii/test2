# Copy this file to .env.local for local dev.
# Put the same real values in Vercel Project Settings -> Environment Variables.
# Never commit .env.local or real secrets.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- LLM qualification ---
AI_PROVIDER=gemini
AI_API_KEY=your_real_gemini_api_key_here
AI_MODEL=gemini-2.5-flash-lite
AI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash-lite,gemini-2.0-flash
AI_LIMIT=50
AI_DELAY_MS=12000

# Optional backwards-compatible Gemini key. Prefer AI_API_KEY above.
GEMINI_API_KEY=your_real_gemini_api_key_here

# --- Real extraction APIs ---
ADZUNA_APP_ID=your_real_adzuna_app_id_here
ADZUNA_APP_KEY=your_real_adzuna_app_key_here
PRODUCT_HUNT_TOKEN=your_real_product_hunt_token_here

# --- Runtime data storage ---
# Local dev can omit LEADGRID_DATA_DIR to use ./data.
# Vercel should use /tmp/leadgrid-data and sync durable files through Vercel Blob.
LEADGRID_DATA_DIR=/tmp/leadgrid-data
BLOB_READ_WRITE_TOKEN=your_vercel_blob_read_write_token_here
LEADGRID_BLOB_PREFIX=leadgrid/data
