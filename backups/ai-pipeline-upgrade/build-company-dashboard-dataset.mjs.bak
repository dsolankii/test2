import fs from "node:fs";

const PRECLEAN_JSON = "data/real-source-mentions-preclean.json";
const REJECTED_JSON = "data/real-source-mentions-rejected-preclean.json";
const AI_COMPANY_JSON = "data/ai-enriched-company-leads.json";

const OUTPUT_JSON = "data/company-dashboard-leads.json";
const OUTPUT_CSV = "data/company-dashboard-leads.csv";
const DASHBOARD_JSON = "data/raw-company-mentions.json";

function cleanText(value = "") {
  return String(value)
    .replace(/[�]/g, "")
    .replace(/\r?\n|\r/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function normalizeCompanyName(name = "") {
  return cleanText(name)
    .toLowerCase()
    .replace(/\b(inc|inc\.|llc|ltd|ltd\.|corp|corp\.|corporation|company|co|co\.|limited|plc|gmbh|sa|ag)\b/g, "")
    .replace(/[^a-z0-9]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function companyKeyFromName(name = "") {
  return normalizeCompanyName(name) || cleanText(name).toLowerCase().replace(/[^a-z0-9]+/g, "_");
}

function unique(values) {
  return [...new Set(values.filter(Boolean).map(cleanText).filter(Boolean))];
}

function hasAny(text, terms) {
  return terms.some((term) => text.includes(term));
}

function groupRows(rows) {
  const map = new Map();

  for (const row of rows) {
    const key = companyKeyFromName(row.rawName);
    if (!key) continue;

    if (!map.has(key)) {
      map.set(key, {
        companyKey: key,
        companyName: cleanText(row.rawName),
        rows: [],
        websites: [],
        sourceNames: [],
        sourceTypes: [],
        sourceUrls: [],
        countries: [],
        latestActivityDate: "",
      });
    }

    const company = map.get(key);
    company.rows.push(row);
    company.websites.push(row.website || "");
    company.sourceNames.push(row.sourceName || "");
    company.sourceTypes.push(row.sourceType || "");
    company.sourceUrls.push(row.sourceUrl || "");
    company.countries.push(row.country || "");

    const date = cleanText(row.lastActivityDate || "");
    if (date && date > company.latestActivityDate) company.latestActivityDate = date;
  }

  return [...map.values()].map((company) => ({
    ...company,
    websites: unique(company.websites),
    sourceNames: unique(company.sourceNames),
    sourceTypes: unique(company.sourceTypes),
    sourceUrls: unique(company.sourceUrls).slice(0, 8),
    countries: unique(company.countries),
    mentionCount: company.rows.length,
    combinedText: company.rows
      .map((row) =>
        [
          row.description,
          row.homepageText,
          row.careersText,
          row.stageHint,
          row.precleanReason,
        ]
          .filter(Boolean)
          .join(" ")
      )
      .join(" | "),
  }));
}

function localScore(company) {
  const text = [
    company.companyName,
    company.sourceNames.join(" "),
    company.sourceTypes.join(" "),
    company.combinedText,
  ]
    .join(" ")
    .toLowerCase();

  const breakdown = {
    gtmHiring: 0,
    growthSignal: 0,
    icpFit: 0,
    sourceStrength: 0,
    urgency: 0,
    negativePenalty: 0,
  };

  const signals = [];

  if (hasAny(text, ["account executive", "business development", "sdr", "bdr", "sales", "revenue", "revops", "gtm", "go-to-market", "partnership"])) {
    breakdown.gtmHiring = hasAny(text, ["account executive", "business development", "sdr", "bdr"]) ? 35 : 25;
    signals.push("GTM/sales hiring signal");
  }

  if (hasAny(text, ["growth", "demand generation", "lead generation", "marketing", "customer success", "expansion"])) {
    breakdown.growthSignal = 18;
    signals.push("Growth or demand generation signal");
  }

  if (hasAny(text, ["saas", "b2b", "software", "platform", "enterprise", "crm", "automation", "cloud", "security", "ai", "fintech", "ecommerce", "payments", "retail"])) {
    breakdown.icpFit = 18;
    signals.push("ICP/company fit signal");
  } else {
    breakdown.icpFit = 8;
  }

  if (company.sourceTypes.includes("conference")) {
    breakdown.sourceStrength += 8;
    signals.push("Conference/exhibitor visibility");
  }

  if (company.sourceNames.some((name) => name.includes("Adzuna") || name.includes("Jobicy") || name.includes("Remote OK") || name.includes("Remotive"))) {
    breakdown.sourceStrength += 7;
    signals.push("Active hiring source");
  }

  if (company.mentionCount >= 3) {
    breakdown.urgency += 6;
    signals.push("Multiple source mentions");
  } else if (company.mentionCount >= 2) {
    breakdown.urgency += 3;
  }

  if (hasAny(text, ["admin assistant", "clinical", "nurse", "doctor", "data entry", "staffing agency", "recruitment consultant"])) {
    breakdown.negativePenalty = -40;
    signals.push("Negative/noisy signal");
  }

  const score = Math.max(
    0,
    Math.min(
      100,
      breakdown.gtmHiring +
        breakdown.growthSignal +
        breakdown.icpFit +
        breakdown.sourceStrength +
        breakdown.urgency +
        breakdown.negativePenalty
    )
  );

  const category = score >= 85 ? "high_intent" : score >= 65 ? "medium_intent" : score >= 40 ? "low_intent" : "trash";

  return {
    score,
    category,
    buyingStage: category === "trash" ? "not_relevant" : category,
    icpFit: score >= 85 ? "high" : score >= 45 ? "medium" : "low",
    signals,
    breakdown,
    companyType: hasAny(text, ["saas", "software", "platform", "cloud", "crm", "automation", "security", "ai"])
      ? "b2b_software"
      : hasAny(text, ["fintech", "payments", "banking"])
        ? "fintech"
        : hasAny(text, ["ecommerce", "retail", "commerce"])
          ? "ecommerce"
          : "unknown",
  };
}

function toLocalDashboardRow(company) {
  const local = localScore(company);

  return {
    companyKey: company.companyKey,
    id: `company_${company.companyKey.replace(/[^a-z0-9]+/g, "_")}`,
    rawName: company.companyName,
    website: company.websites[0] || "",
    sourceType: company.sourceTypes.join("; "),
    sourceName: company.sourceNames.join("; "),
    sourceUrl: company.sourceUrls.join("; "),
    description: `Local weighted score: ${local.signals.join(", ") || "weak signal"}.`,
    homepageText: cleanText(
      [
        `Local why now: ${local.score >= 65 ? "Recent hiring, GTM language, or market visibility suggests growth motion." : "Some activity exists but buying intent is weaker."}`,
        `Local outreach angle: ${local.score >= 65 ? "Offer appointment-setting support to convert growth signals into qualified meetings." : "Use a light discovery angle."}`,
        `Merged from ${company.mentionCount} source mention(s).`,
        company.combinedText,
      ].join(" ")
    ),
    careersText: "",
    lastActivityDate: company.latestActivityDate,
    country: company.countries.join("; "),
    mentionCount: company.mentionCount,
    stageHint: "company_level_local_fallback",
    agentConfidence: local.score / 100,
    expectedCategory: local.category,
    expectedTrashReason: local.category === "trash" ? "Low weighted fallback score." : "",
    aiGenerated: false,
    aiProvider: "local-weighted-fallback",
    aiModel: "weighted-v2-company-level",
    aiCompanyType: local.companyType,
    aiIsPotentialCustomer: local.score >= 40,
    aiIsBadLead: local.score < 40,
    aiBadLeadReason: local.score < 40 ? "Low weighted fallback score." : "",
    aiIcpFit: local.icpFit,
    aiBuyingStage: local.buyingStage,
    aiSignals: local.signals,
    aiIntentScore: local.score,
    aiScoreBreakdown: local.breakdown,
    aiScoreReasoning: `Weighted fallback score using GTM hiring, growth signal, ICP fit, source strength, urgency, and penalties.`,
    aiWhyNow: local.score >= 65 ? "Recent hiring, GTM language, or market visibility suggests growth motion." : "Some activity exists but buying intent is weaker.",
    aiRecommendedBuyer: local.score >= 65 ? "VP Sales, Head of Growth, Revenue Leader, Founder, GTM Lead" : "Founder, Operations Lead, Marketing Lead",
    aiOutreachAngle: local.score >= 65 ? "Offer appointment-setting support to convert growth signals into qualified meetings." : "Use a light discovery angle.",
  };
}

function csvEscape(value) {
  if (value === undefined || value === null) return "";
  const str = Array.isArray(value) ? value.join("; ") : typeof value === "object" ? JSON.stringify(value) : String(value);
  return `"${cleanText(str).replace(/"/g, '""')}"`;
}

function writeCsv(rows, path) {
  const headers = [
    "companyKey",
    "rawName",
    "website",
    "sourceType",
    "sourceName",
    "sourceUrl",
    "description",
    "homepageText",
    "lastActivityDate",
    "country",
    "mentionCount",
    "expectedCategory",
    "expectedTrashReason",
    "aiGenerated",
    "aiProvider",
    "aiModel",
    "aiCompanyType",
    "aiIcpFit",
    "aiBuyingStage",
    "aiIntentScore",
    "aiScoreBreakdown",
    "aiSignals",
    "aiScoreReasoning",
    "aiWhyNow",
    "aiRecommendedBuyer",
    "aiOutreachAngle",
  ];

  const csv = [
    headers.join(","),
    ...rows.map((row) => headers.map((header) => csvEscape(row[header])).join(",")),
  ].join("\n");

  fs.writeFileSync(path, csv);
}

if (!fs.existsSync(PRECLEAN_JSON)) {
  console.error(`Missing ${PRECLEAN_JSON}`);
  process.exit(1);
}

const precleanRows = JSON.parse(fs.readFileSync(PRECLEAN_JSON, "utf-8"));
const rejectedRows = fs.existsSync(REJECTED_JSON) ? JSON.parse(fs.readFileSync(REJECTED_JSON, "utf-8")) : [];
const aiRows = fs.existsSync(AI_COMPANY_JSON) ? JSON.parse(fs.readFileSync(AI_COMPANY_JSON, "utf-8")) : [];

const companies = groupRows(precleanRows);
const aiByCompanyKey = new Map(aiRows.map((row) => [row.companyKey, row]));

const acceptedDashboardRows = companies.map((company) => {
  const aiRow = aiByCompanyKey.get(company.companyKey);
  if (aiRow) return aiRow;
  return toLocalDashboardRow(company);
});

const rejectedCompanies = groupRows(rejectedRows).map((company) => ({
  companyKey: company.companyKey,
  id: `trash_${company.companyKey.replace(/[^a-z0-9]+/g, "_")}`,
  rawName: company.companyName,
  website: company.websites[0] || "",
  sourceType: company.sourceTypes.join("; "),
  sourceName: company.sourceNames.join("; "),
  sourceUrl: company.sourceUrls.join("; "),
  description: "Rejected during pre-cleaning.",
  homepageText: company.combinedText,
  careersText: "",
  lastActivityDate: company.latestActivityDate,
  country: company.countries.join("; "),
  mentionCount: company.mentionCount,
  stageHint: "preclean_rejected",
  agentConfidence: 0.05,
  expectedCategory: "trash",
  expectedTrashReason: "Rejected during pre-cleaning as obvious noise or weak buying signal.",
  aiGenerated: false,
  aiProvider: "preclean-rules",
  aiModel: "deterministic-v1",
  aiCompanyType: "unknown",
  aiIsPotentialCustomer: false,
  aiIsBadLead: true,
  aiBadLeadReason: "Rejected during pre-cleaning.",
  aiIcpFit: "low",
  aiBuyingStage: "not_relevant",
  aiSignals: [],
  aiIntentScore: 0,
  aiScoreBreakdown: {},
  aiScoreReasoning: "Rejected during pre-cleaning.",
  aiWhyNow: "",
  aiRecommendedBuyer: "",
  aiOutreachAngle: "",
}));

const finalRows = [...acceptedDashboardRows, ...rejectedCompanies].sort(
  (a, b) => Number(b.aiIntentScore || 0) - Number(a.aiIntentScore || 0)
);

fs.writeFileSync(OUTPUT_JSON, JSON.stringify(finalRows, null, 2));
fs.writeFileSync(DASHBOARD_JSON, JSON.stringify(finalRows, null, 2));
writeCsv(finalRows, OUTPUT_CSV);

console.log("Company-level dashboard dataset built");
console.log("-------------------------------------");
console.log(`Pre-clean rows: ${precleanRows.length}`);
console.log(`Unique accepted companies: ${companies.length}`);
console.log(`AI-enriched companies used: ${aiRows.length}`);
console.log(`Local fallback companies: ${acceptedDashboardRows.filter((row) => row.aiProvider === "local-weighted-fallback").length}`);
console.log(`Rejected companies: ${rejectedCompanies.length}`);
console.log(`Final dashboard company rows: ${finalRows.length}`);
console.log(`Wrote ${OUTPUT_JSON}`);
console.log(`Wrote ${OUTPUT_CSV}`);
console.log(`Updated ${DASHBOARD_JSON}`);
